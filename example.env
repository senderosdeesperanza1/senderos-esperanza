# Copia este archivo como .env y rellena los valores.
# En producción (servidor) usa estos mismos nombres de variables.

# Base de datos MySQL (obligatorio en producción)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=senderos_db

# URL de tu sitio (para enlaces y redirecciones)
APP_URL=https://senderosdeesperanza.com

# Seguridad: genera una clave larga y aleatoria para JWT
JWT_SECRET=CLAVE_SECRETA_SUPER_SEGURA_CAMBIAR_EN_PRODUCCION

# Wompi (donaciones) - opcional
WOMPI_PUBLIC_KEY=pub_test_your_public_key
WOMPI_PRIVATE_KEY=prv_test_your_private_key
WOMPI_EVENTS_KEY=your_events_key
